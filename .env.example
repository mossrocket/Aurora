# Aurora Space Health — environment variables
# Copy to .env.local for local dev, and set the same keys in Vercel → Project → Settings → Environment Variables.

# ── Web Push (VAPID) ──────────────────────────────────────────────────────────
# Generate a keypair once with:  npx web-push generate-vapid-keys
# Public key is exposed to the browser (must be prefixed VITE_ so Vite inlines it).
VITE_VAPID_PUBLIC_KEY=
# Same public key, available to serverless functions (no VITE_ prefix).
VAPID_PUBLIC_KEY=
# Private key — KEEP SECRET. Server only. Never commit.
VAPID_PRIVATE_KEY=
# Contact for push services — a mailto: or https URL.
VAPID_SUBJECT=mailto:peteragray@gmail.com

# ── Upstash Redis (stores anonymous push subscriptions) ───────────────────────
# Create a database at https://console.upstash.com → copy the REST URL + token.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Cron protection ───────────────────────────────────────────────────────────
# Set any random string. Vercel Cron automatically sends it as a Bearer token to
# /api/cron/check-kp; manual calls can pass ?secret=THIS_VALUE.
CRON_SECRET=

# ── Optional tuning ───────────────────────────────────────────────────────────
# Kp level that triggers an alert when crossed upward (default 5 = NOAA G1 storm).
KP_ALERT_THRESHOLD=5
